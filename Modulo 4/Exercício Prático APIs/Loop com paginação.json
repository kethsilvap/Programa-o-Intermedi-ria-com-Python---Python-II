while True:
    params = {
        "api_key": API_KEY,
        "sol": max_sol,
        "page": page
    }

    response = requests.get(url_photos, params=params)
    data = response.json()

    photos = data.get("photos")

    # 🔴 parar quando não houver mais resultados
    if not photos:
        print(f"Fim na página {page}")
        break

    print(f"Página {page} - {len(photos)} fotos")

    for photo in photos:
        camera_name = photo["camera"]["name"]

        if camera_name in camera_filter:
            img_url = photo["img_src"]
            img_id = photo["id"]

            try:
                img = io.imread(img_url)

                plt.imshow(img)
                plt.title(f"Page {page} | {camera_name} | ID {img_id}")
                plt.axis("off")
                plt.show()

            except Exception as e:
                print("Erro ao carregar imagem:", e)

    page += 1